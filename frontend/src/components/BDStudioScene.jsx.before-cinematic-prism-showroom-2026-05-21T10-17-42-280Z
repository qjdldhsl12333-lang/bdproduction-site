import {
    ContactShadows,
    Environment,
    Float,
    MeshReflectorMaterial,
    RoundedBox,
    Text,
} from '@react-three/drei';
import { useFrame, useThree } from '@react-three/fiber';
import { useEffect, useMemo, useRef, useState } from 'react';
import * as THREE from 'three';

const lime = '#95ff00';
const cyan = '#18a1aa';
const deep = '#020407';

function BDStudioScene({ isPlaying }) {
    const stageRef = useRef(null);
    const { pointer } = useThree();

    useFrame((state) => {
        if (!stageRef.current) {
            return;
        }

        const elapsed = state.clock.elapsedTime;
        const targetY = pointer.x * 0.22 + Math.sin(elapsed * 0.32) * 0.035;
        const targetX = -pointer.y * 0.08 + Math.sin(elapsed * 0.24) * 0.012;

        stageRef.current.rotation.y = THREE.MathUtils.lerp(stageRef.current.rotation.y, targetY, 0.055);
        stageRef.current.rotation.x = THREE.MathUtils.lerp(stageRef.current.rotation.x, targetX, 0.05);
    });

    return (
        <>
            <color attach="background" args={[deep]} />
            <fog attach="fog" args={[deep, 5.4, 14]} />

            <ambientLight intensity={0.22} />
            <spotLight
                position={[-3.8, 4.8, 3.2]}
                angle={0.52}
                penumbra={0.72}
                intensity={5.4}
                color={lime}
                castShadow
            />
            <spotLight
                position={[3.2, 3.6, 4.2]}
                angle={0.55}
                penumbra={0.82}
                intensity={2.8}
                color={cyan}
            />
            <pointLight position={[0, 1.35, 1.4]} intensity={1.7} color={lime} />
            <pointLight position={[0, 2.4, -2.2]} intensity={2.5} color={cyan} />

            <Environment preset="night" />

            <group ref={stageRef} position={[0, -0.74, 0]}>
                <CinematicShowroom isPlaying={isPlaying} />
            </group>

            <ContactShadows
                position={[0, -1.24, 0]}
                opacity={0.34}
                scale={8.5}
                blur={2.6}
                far={4.5}
            />
        </>
    );
}

function CinematicShowroom({ isPlaying }) {
    return (
        <group>
            <ReflectiveStage />
            <BackRings />
            <LightRails />
            <MainScreen isPlaying={isPlaying} />
            <GlassPanels />
            <FloatingCore />
            <FloatingCodeFragments />
        </group>
    );
}

function ReflectiveStage() {
    return (
        <group>
            <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, -0.52, 0]} receiveShadow>
                <planeGeometry args={[7.2, 4.3]} />
                <MeshReflectorMaterial
                    blur={[420, 110]}
                    resolution={1024}
                    mixBlur={1.15}
                    mixStrength={2.8}
                    roughness={0.48}
                    depthScale={0.72}
                    minDepthThreshold={0.18}
                    maxDepthThreshold={1.1}
                    color="#02090a"
                    metalness={0.72}
                />
            </mesh>

            <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, -0.505, 0.15]}>
                <ringGeometry args={[1.65, 1.68, 96]} />
                <meshBasicMaterial color={lime} transparent opacity={0.32} />
            </mesh>

            <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, -0.502, 0.15]}>
                <ringGeometry args={[2.85, 2.88, 128]} />
                <meshBasicMaterial color={cyan} transparent opacity={0.14} />
            </mesh>
        </group>
    );
}

function BackRings() {
    return (
        <group position={[0, 1.1, -1.95]}>
            {[0, 1, 2].map((index) => (
                <Float
                    key={index}
                    speed={0.5 + index * 0.15}
                    rotationIntensity={0.08}
                    floatIntensity={0.05}
                >
                    <mesh
                        rotation={[0, 0, index * 0.22]}
                        scale={[1 + index * 0.34, 1 + index * 0.34, 1]}
                    >
                        <torusGeometry args={[1.48, 0.012, 18, 160]} />
                        <meshBasicMaterial
                            color={index === 1 ? cyan : lime}
                            transparent
                            opacity={index === 0 ? 0.38 : 0.18}
                        />
                    </mesh>
                </Float>
            ))}

            <mesh position={[0, 0, -0.04]}>
                <circleGeometry args={[2.58, 96]} />
                <meshBasicMaterial color="#031314" transparent opacity={0.72} />
            </mesh>
        </group>
    );
}

function LightRails() {
    const rails = [
        [-2.9, -0.48, -0.9, 0.01, lime],
        [2.9, -0.48, -0.9, -0.01, cyan],
        [-2.15, -0.46, 1.04, 0.02, cyan],
        [2.15, -0.46, 1.04, -0.02, lime],
    ];

    return (
        <group>
            {rails.map(([x, y, z, rotationZ, color], index) => (
                <mesh key={index} position={[x, y, z]} rotation={[-Math.PI / 2, 0, rotationZ]}>
                    <boxGeometry args={[0.026, 2.8, 0.012]} />
                    <meshBasicMaterial color={color} transparent opacity={0.5} />
                </mesh>
            ))}
        </group>
    );
}

function MainScreen({ isPlaying }) {
    return (
        <group position={[0, 1.08, -1.18]}>
            <RoundedBox args={[3.42, 1.78, 0.16]} radius={0.08} smoothness={6} castShadow>
                <meshPhysicalMaterial
                    color="#05090a"
                    metalness={0.85}
                    roughness={0.26}
                    clearcoat={1}
                    clearcoatRoughness={0.18}
                />
            </RoundedBox>

            <mesh position={[0, 0, 0.087]}>
                <planeGeometry args={[3.08, 1.38]} />
                <meshBasicMaterial color="#000000" />
            </mesh>

            <VideoScreen isPlaying={isPlaying} />

            <mesh position={[0, 0, 0.1]}>
                <planeGeometry args={[3.12, 1.42]} />
                <meshPhysicalMaterial
                    color="#ffffff"
                    transparent
                    opacity={0.045}
                    roughness={0.05}
                    metalness={0.2}
                    clearcoat={1}
                    clearcoatRoughness={0.04}
                />
            </mesh>

            <mesh position={[0, -1.0, 0.02]} castShadow>
                <boxGeometry args={[2.1, 0.1, 0.18]} />
                <meshStandardMaterial
                    color="#071012"
                    emissive={lime}
                    emissiveIntensity={0.07}
                    metalness={0.55}
                    roughness={0.32}
                />
            </mesh>
        </group>
    );
}

function VideoScreen({ isPlaying }) {
    const [videoReady, setVideoReady] = useState(false);

    const video = useMemo(() => {
        const element = document.createElement('video');

        element.src = '/videos/showreel.mp4';
        element.crossOrigin = 'anonymous';
        element.loop = true;
        element.muted = true;
        element.playsInline = true;
        element.preload = 'auto';

        return element;
    }, []);

    const texture = useMemo(() => {
        const videoTexture = new THREE.VideoTexture(video);

        videoTexture.colorSpace = THREE.SRGBColorSpace;
        videoTexture.minFilter = THREE.LinearFilter;
        videoTexture.magFilter = THREE.LinearFilter;

        return videoTexture;
    }, [video]);

    useEffect(() => {
        const handleCanPlay = () => {
            setVideoReady(true);
        };

        const handleError = () => {
            setVideoReady(false);
        };

        video.addEventListener('canplay', handleCanPlay);
        video.addEventListener('error', handleError);

        return () => {
            video.pause();
            video.removeEventListener('canplay', handleCanPlay);
            video.removeEventListener('error', handleError);
            texture.dispose();
        };
    }, [texture, video]);

    useEffect(() => {
        if (!videoReady) {
            return;
        }

        if (isPlaying) {
            video.play().catch(() => {
                setVideoReady(false);
            });
        } else {
            video.pause();
        }
    }, [isPlaying, video, videoReady]);

    if (videoReady) {
        return (
            <mesh position={[0, 0, 0.104]}>
                <planeGeometry args={[3.0, 1.28]} />
                <meshBasicMaterial map={texture} toneMapped={false} />
            </mesh>
        );
    }

    return (
        <group position={[0, 0, 0.106]}>
            <mesh>
                <planeGeometry args={[3.0, 1.28]} />
                <meshBasicMaterial color="#010202" />
            </mesh>

            <Text
                position={[0, 0.09, 0.01]}
                fontSize={0.18}
                color="#f8fff2"
                anchorX="center"
                anchorY="middle"
                outlineWidth={0.004}
                outlineColor="#95ff00"
            >
                BDPRODUCTION
            </Text>

            <Text
                position={[0, -0.13, 0.01]}
                fontSize={0.055}
                color="#95ff00"
                anchorX="center"
                anchorY="middle"
            >
                SHOWREEL SYSTEM READY
            </Text>
        </group>
    );
}

function GlassPanels() {
    const panels = [
        [-1.95, 0.84, -0.18, 0.26],
        [1.95, 0.84, -0.18, -0.26],
        [-2.45, 0.45, 0.86, 0.34],
        [2.45, 0.45, 0.86, -0.34],
    ];

    return (
        <group>
            {panels.map(([x, y, z, rotationY], index) => (
                <Float
                    key={index}
                    speed={1.1 + index * 0.11}
                    rotationIntensity={0.07}
                    floatIntensity={0.08}
                >
                    <RoundedBox
                        args={[0.58, 1.24, 0.035]}
                        radius={0.04}
                        smoothness={4}
                        position={[x, y, z]}
                        rotation={[0, rotationY, 0]}
                    >
                        <meshPhysicalMaterial
                            color={index % 2 === 0 ? cyan : lime}
                            transparent
                            opacity={0.18}
                            metalness={0.2}
                            roughness={0.08}
                            transmission={0.1}
                            clearcoat={1}
                            clearcoatRoughness={0.04}
                        />
                    </RoundedBox>
                </Float>
            ))}
        </group>
    );
}

function FloatingCore() {
    const coreRef = useRef(null);

    useFrame((state) => {
        if (!coreRef.current) {
            return;
        }

        const elapsed = state.clock.elapsedTime;
        coreRef.current.rotation.x = elapsed * 0.23;
        coreRef.current.rotation.y = elapsed * 0.32;
    });

    return (
        <Float speed={1.5} rotationIntensity={0.12} floatIntensity={0.22}>
            <group ref={coreRef} position={[0, 0.22, 0.72]}>
                <mesh castShadow>
                    <icosahedronGeometry args={[0.34, 1]} />
                    <meshPhysicalMaterial
                        color="#101815"
                        emissive={lime}
                        emissiveIntensity={0.18}
                        metalness={0.8}
                        roughness={0.18}
                        clearcoat={1}
                        clearcoatRoughness={0.05}
                    />
                </mesh>

                <mesh rotation={[Math.PI / 2, 0, 0]}>
                    <torusGeometry args={[0.62, 0.012, 16, 120]} />
                    <meshBasicMaterial color={lime} transparent opacity={0.72} />
                </mesh>

                <mesh rotation={[0, Math.PI / 2, 0]}>
                    <torusGeometry args={[0.74, 0.01, 16, 120]} />
                    <meshBasicMaterial color={cyan} transparent opacity={0.42} />
                </mesh>
            </group>
        </Float>
    );
}

function FloatingCodeFragments() {
    return (
        <group>
            {['8K', 'CINE', 'COLOR', 'REEL'].map((label, index) => {
                const x = [-2.2, -1.4, 1.5, 2.25][index];
                const y = [1.92, 2.22, 2.08, 1.72][index];
                const z = [-1.35, -1.72, -1.46, -1.24][index];

                return (
                    <Float key={label} speed={1.1 + index * 0.16} rotationIntensity={0.08} floatIntensity={0.12}>
                        <Text
                            position={[x, y, z]}
                            rotation={[0.08, index < 2 ? 0.26 : -0.26, 0]}
                            fontSize={0.075}
                            color={index % 2 === 0 ? lime : cyan}
                            anchorX="center"
                            anchorY="middle"
                        >
                            {label}
                        </Text>
                    </Float>
                );
            })}
        </group>
    );
}

export default BDStudioScene;