import { ContactShadows, Environment, Float, MeshReflectorMaterial, Sparkles, Text } from '@react-three/drei';
import { useFrame } from '@react-three/fiber';
import { useEffect, useMemo, useRef, useState } from 'react';
import * as THREE from 'three';

function BDStudioScene({ isPlaying }) {
  const stageRef = useRef(null);
  const coreRef = useRef(null);
  const screenRef = useRef(null);

  useFrame((state, delta) => {
    const elapsed = state.clock.elapsedTime;
    const pointerX = THREE.MathUtils.clamp(state.pointer.x, -1, 1);
    const pointerY = THREE.MathUtils.clamp(state.pointer.y, -1, 1);

    if (stageRef.current) {
      stageRef.current.rotation.y = THREE.MathUtils.lerp(
        stageRef.current.rotation.y,
        pointerX * 0.16 + Math.sin(elapsed * 0.32) * 0.025,
        0.055,
      );
      stageRef.current.rotation.x = THREE.MathUtils.lerp(
        stageRef.current.rotation.x,
        -pointerY * 0.045,
        0.055,
      );
    }

    if (coreRef.current) {
      coreRef.current.rotation.y += delta * 0.42;
      coreRef.current.rotation.z = Math.sin(elapsed * 0.7) * 0.08;
    }

    if (screenRef.current) {
      screenRef.current.position.y = 0.48 + Math.sin(elapsed * 0.75) * 0.035;
    }
  });

  return (
    <>
      <color attach="background" args={['#020407']} />
      <fog attach="fog" args={['#020407', 5.6, 13]} />
      <ambientLight intensity={0.22} />
      <directionalLight position={[2.8, 4.2, 3.2]} intensity={1.65} color="#effff7" castShadow />
      <pointLight position={[-2.4, 1.8, 1.2]} intensity={2.4} color="#95ff00" distance={6.8} />
      <pointLight position={[2.5, 2.2, 0.2]} intensity={1.7} color="#18a1aa" distance={7.2} />
      <spotLight position={[0, 5.4, 2.8]} angle={0.42} penumbra={0.75} intensity={3.2} color="#dfffee" castShadow />
      <Environment preset="city" />

      <group ref={stageRef} position={[0, -0.42, 0]}>
        <ReflectiveFloor />
        <BackHalo />
        <HeroScreen refObject={screenRef} isPlaying={isPlaying} />
        <OrbitArchitecture />
        <FloatingGlassCards />
        <ChromeCore refObject={coreRef} />
        <LightRunways />
        <Sparkles
          count={72}
          scale={[5.6, 2.6, 3.4]}
          size={1.8}
          speed={0.35}
          opacity={0.42}
          color="#95ff00"
        />
      </group>

      <ContactShadows position={[0, -1.12, 0]} opacity={0.42} scale={7.6} blur={2.8} far={4.8} />
    </>
  );
}

function ReflectiveFloor() {
  return (
    <mesh rotation={[-Math.PI / 2, 0, 0]} position={[0, -1.12, 0]} receiveShadow>
      <planeGeometry args={[8.6, 5.4]} />
      <MeshReflectorMaterial
        blur={[420, 120]}
        resolution={1024}
        mixBlur={0.9}
        mixStrength={2.6}
        roughness={0.38}
        depthScale={0.62}
        minDepthThreshold={0.35}
        maxDepthThreshold={1.35}
        color="#050b0c"
        metalness={0.74}
      />
    </mesh>
  );
}

function BackHalo() {
  return (
    <group position={[0, 0.46, -1.52]}>
      <mesh>
        <torusGeometry args={[1.72, 0.012, 16, 160]} />
        <meshBasicMaterial color="#95ff00" transparent opacity={0.55} />
      </mesh>
      <mesh rotation={[0, 0, Math.PI / 2]}>
        <torusGeometry args={[1.18, 0.008, 16, 160]} />
        <meshBasicMaterial color="#18a1aa" transparent opacity={0.32} />
      </mesh>
      <mesh position={[0, 0, -0.025]}>
        <planeGeometry args={[4.2, 2.34]} />
        <meshBasicMaterial color="#041a21" transparent opacity={0.32} />
      </mesh>
    </group>
  );
}

function HeroScreen({ refObject, isPlaying }) {
  return (
    <group ref={refObject} position={[0, 0.48, -1.16]}>
      <mesh position={[0, 0, -0.05]} castShadow>
        <boxGeometry args={[3.96, 1.78, 0.13]} />
        <meshStandardMaterial color="#050607" roughness={0.42} metalness={0.72} />
      </mesh>
      <mesh position={[0, -1.02, 0.02]} castShadow>
        <boxGeometry args={[3.72, 0.055, 0.13]} />
        <meshStandardMaterial color="#95ff00" emissive="#95ff00" emissiveIntensity={1.15} roughness={0.28} />
      </mesh>
      <VideoPlane isPlaying={isPlaying} />
    </group>
  );
}

function VideoPlane({ isPlaying }) {
  const [videoReady, setVideoReady] = useState(false);

  const video = useMemo(() => {
    if (typeof document === 'undefined') {
      return null;
    }

    const element = document.createElement('video');
    element.src = '/videos/showreel.mp4';
    element.crossOrigin = 'anonymous';
    element.loop = true;
    element.muted = true;
    element.playsInline = true;
    element.preload = 'auto';
    return element;
  }, []);

  const texture = useMemo(() => {
    if (!video) {
      return null;
    }

    const videoTexture = new THREE.VideoTexture(video);
    videoTexture.colorSpace = THREE.SRGBColorSpace;
    videoTexture.minFilter = THREE.LinearFilter;
    videoTexture.magFilter = THREE.LinearFilter;
    return videoTexture;
  }, [video]);

  useEffect(() => {
    if (!video || !texture) {
      return undefined;
    }

    const handleCanPlay = () => setVideoReady(true);
    const handleError = () => setVideoReady(false);

    video.addEventListener('canplay', handleCanPlay);
    video.addEventListener('error', handleError);

    return () => {
      video.pause();
      video.removeEventListener('canplay', handleCanPlay);
      video.removeEventListener('error', handleError);
      texture.dispose();
    };
  }, [texture, video]);

  useEffect(() => {
    if (!video || !videoReady) {
      return;
    }

    if (isPlaying) {
      video.play().catch(() => setVideoReady(false));
    } else {
      video.pause();
    }
  }, [isPlaying, video, videoReady]);

  return (
    <group position={[0, 0, 0.03]}>
      <mesh>
        <planeGeometry args={[3.46, 1.22]} />
        {videoReady && texture ? (
          <meshBasicMaterial map={texture} toneMapped={false} />
        ) : (
          <meshStandardMaterial color="#020405" emissive="#081d1b" emissiveIntensity={1.35} roughness={0.48} />
        )}
      </mesh>

      {!videoReady && (
        <>
          <Text position={[0, 0.09, 0.024]} fontSize={0.18} color="#f5f7ee" anchorX="center" anchorY="middle">
            BDPRODUCTION
          </Text>
          <Text position={[0, -0.14, 0.024]} fontSize={0.06} color="#95ff00" anchorX="center" anchorY="middle" letterSpacing={0.08}>
            PREMIUM VIDEO PRODUCTION STUDIO
          </Text>
        </>
      )}

      <mesh position={[0, 0.65, 0.026]}>
        <planeGeometry args={[3.38, 0.015]} />
        <meshBasicMaterial color="#95ff00" transparent opacity={0.7} />
      </mesh>
      <mesh position={[0, -0.65, 0.026]}>
        <planeGeometry args={[3.38, 0.015]} />
        <meshBasicMaterial color="#18a1aa" transparent opacity={0.42} />
      </mesh>
    </group>
  );
}

function OrbitArchitecture() {
  const ringRef = useRef(null);
  const secondRingRef = useRef(null);

  useFrame((state, delta) => {
    if (ringRef.current) {
      ringRef.current.rotation.z += delta * 0.18;
    }
    if (secondRingRef.current) {
      secondRingRef.current.rotation.z -= delta * 0.14;
    }
  });

  return (
    <group position={[0, 0.55, -1.05]}>
      <mesh ref={ringRef} rotation={[Math.PI / 2.55, 0.25, 0.22]}>
        <torusGeometry args={[1.42, 0.008, 12, 170]} />
        <meshBasicMaterial color="#f5f7ee" transparent opacity={0.32} />
      </mesh>
      <mesh ref={secondRingRef} rotation={[Math.PI / 2.2, -0.28, -0.15]}>
        <torusGeometry args={[1.02, 0.007, 12, 150]} />
        <meshBasicMaterial color="#95ff00" transparent opacity={0.42} />
      </mesh>
      <mesh rotation={[Math.PI / 2, 0, 0]} position={[0, -1.12, 0.32]}>
        <torusGeometry args={[1.75, 0.012, 12, 190]} />
        <meshBasicMaterial color="#95ff00" transparent opacity={0.5} />
      </mesh>
    </group>
  );
}

function ChromeCore({ refObject }) {
  return (
    <Float speed={1.15} rotationIntensity={0.14} floatIntensity={0.12}>
      <group ref={refObject} position={[0, 0.52, 0.18]} rotation={[0.34, 0.46, 0.2]}>
        <mesh castShadow>
          <octahedronGeometry args={[0.42, 1]} />
          <meshPhysicalMaterial
            color="#cfeee8"
            roughness={0.1}
            metalness={0.62}
            clearcoat={1}
            clearcoatRoughness={0.08}
            transmission={0.22}
            thickness={0.55}
          />
        </mesh>
        <mesh scale={[1.08, 1.08, 1.08]}>
          <octahedronGeometry args={[0.44, 1]} />
          <meshBasicMaterial color="#95ff00" transparent opacity={0.075} wireframe />
        </mesh>
      </group>
    </Float>
  );
}

function FloatingGlassCards() {
  const cards = [
    { position: [-2.35, 0.66, -0.48], rotation: [0.04, 0.46, 0.02], color: '#95ff00' },
    { position: [2.32, 0.74, -0.52], rotation: [0.02, -0.42, -0.02], color: '#18a1aa' },
    { position: [-1.85, -0.1, 0.22], rotation: [-0.06, 0.38, -0.04], color: '#18a1aa' },
    { position: [1.85, -0.08, 0.2], rotation: [-0.04, -0.4, 0.04], color: '#95ff00' },
  ];

  return (
    <group>
      {cards.map((card, index) => (
        <Float key={index} speed={1 + index * 0.14} rotationIntensity={0.08} floatIntensity={0.08}>
          <group position={card.position} rotation={card.rotation}>
            <mesh>
              <boxGeometry args={[0.54, 1.34, 0.022]} />
              <meshPhysicalMaterial
                color="#0b1617"
                transparent
                opacity={0.46}
                roughness={0.12}
                metalness={0.15}
                transmission={0.35}
                thickness={0.35}
                clearcoat={1}
              />
            </mesh>
            <mesh position={[0, 0, 0.017]}>
              <planeGeometry args={[0.42, 0.018]} />
              <meshBasicMaterial color={card.color} transparent opacity={0.86} />
            </mesh>
          </group>
        </Float>
      ))}
    </group>
  );
}

function LightRunways() {
  const lines = [
    { x: -1.9, z: 0.9, rotation: 0.34, color: '#95ff00' },
    { x: 1.9, z: 0.9, rotation: -0.34, color: '#95ff00' },
    { x: -1.4, z: 1.25, rotation: 0.2, color: '#18a1aa' },
    { x: 1.4, z: 1.25, rotation: -0.2, color: '#18a1aa' },
  ];

  return (
    <group position={[0, -1.085, 0]}>
      {lines.map((line, index) => (
        <mesh key={index} position={[line.x, 0.006, line.z]} rotation={[-Math.PI / 2, 0, line.rotation]}>
          <planeGeometry args={[0.025, 2.6]} />
          <meshBasicMaterial color={line.color} transparent opacity={0.72} />
        </mesh>
      ))}
    </group>
  );
}

export default BDStudioScene;
